{
  "private": true,
  "name": "strikeledger",
  "version": "1.3.2",
  "license": "BSD-3-Clause",
  "type": "module",
  "scripts": {
    "build": "npm run check-devvit-settings && vite build",
    "check-devvit-settings": "node scripts/sync-devvit-settings.mjs --check",
    "check-knowledge-graph": "node scripts/generate-knowledge-graph.mjs --check",
    "deploy": "npm run check-devvit-settings && npm run type-check && npm run lint && npm test && devvit upload",
    "dev": "devvit playtest",
    "generate-knowledge-graph": "node scripts/generate-knowledge-graph.mjs",
    "launch": "npm run deploy && devvit publish",
    "lint": "eslint src",
    "login": "devvit login",
    "prettier": "prettier --write .",
    "sync-devvit-settings": "node scripts/sync-devvit-settings.mjs",
    "test": "vitest run --dir src",
    "test:knowledge-graph": "node --test scripts/generate-knowledge-graph.test.mjs",
    "type-check": "tsc --build"
  },
  "engines": {
    "node": ">=22.2.0"
  },
  "dependencies": {
    "@devvit/client": "0.13.5",
    "@devvit/start": "0.13.5",
    "@devvit/web": "0.13.5",
    "@hono/node-server": "^2.0.3",
    "devvit": "0.13.5",
    "hono": "4.12.21"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@types/node": "^22.19.19",
    "eslint": "10.4.0",
    "globals": "17.7.0",
    "prettier": "3.8.3",
    "typescript": "6.0.3",
    "typescript-eslint": "8.59.4",
    "vite": "8.0.13",
    "vitest": "^4.1.7"
  }
}
